# ─────────────────────────────────────────────────────────────────────────────
#  Environment variables required to run this application.
#
#  Development (.env.local):
#    Copy this file to .env.local and fill in values.
#    Vite will inject VITE_* vars into the browser bundle;
#    all others are server-side only.
#
#  Production (Cloudflare Workers):
#    Set secrets via wrangler:
#      wrangler secret put ANTHROPIC_API_KEY
#    Do NOT commit real keys to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Required — Anthropic API key used server-side only (never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-api03-...
